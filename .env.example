# =============================================================================
# PrivacyCam — configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and must NEVER be committed to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# WEBCAM
# -----------------------------------------------------------------------------

# OpenCV device index (0 = first USB webcam, 1 = second, etc.)
WEBCAM_DEVICE=0

# Capture resolution.
# Check what your webcam supports:
#   v4l2-ctl --list-formats-ext --device /dev/video0
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720

# Number of warmup frames to discard before grabbing the keeper.
# Webcams need a few frames to settle auto-exposure and white-balance.
WARMUP_FRAMES=3

# -----------------------------------------------------------------------------
# SCHEDULE
# -----------------------------------------------------------------------------

# How often to run (in minutes). Allowed range: 1–59.
INTERVAL_MINUTES=5

# -----------------------------------------------------------------------------
# YOLO BLUR
# -----------------------------------------------------------------------------

# Path to the YOLO model inside the container.
# The Dockerfile pre-downloads yolov8n.pt to this exact path at build time.
# Change the model file name here AND in the Dockerfile ARG if you want
# a different model (e.g. yolov8s.pt for better accuracy at the cost of speed).
MODEL_PATH=/app/models/yolov8n.pt

# COCO class IDs to blur, comma-separated. 0 = person.
# Full list: https://github.com/ultralytics/ultralytics/blob/main/ultralytics/cfg/datasets/coco.yaml
CLASSES=0

# Detection confidence threshold (0.0–1.0). Lower = more detections, more false positives.
CONF=0.35

# Blur intensity (0.1 = subtle blur, 1.0 = maximum blur).
BLUR_RATIO=0.5

# -----------------------------------------------------------------------------
# OUTPUT
# -----------------------------------------------------------------------------

# Directory inside the container where images are written (bind-mounted from host).
OUT_DIR=/output

# Filename for the always-overwritten "current image".
LATEST_NAME=latest.jpg

# Set to true to also save a timestamped copy alongside latest.jpg.
# Files accumulate — handle rotation/cleanup yourself or leave this false.
WRITE_TIMESTAMPED=false

# -----------------------------------------------------------------------------
# HEALTHCHECK
# -----------------------------------------------------------------------------

# File path where a successful run writes the current Unix epoch timestamp.
HEALTH_FILE=/tmp/last_success_epoch

# Container is considered unhealthy if no successful run occurred within this
# many seconds. Recommended: at least (INTERVAL_MINUTES * 60 * 2).
# Default matches a 5-minute interval with 2 cycles of grace.
HEALTH_MAX_AGE_SECONDS=600

# -----------------------------------------------------------------------------
# FTP / FTPS UPLOAD
# -----------------------------------------------------------------------------

UPLOAD_ENABLED=false

# Protocol to use for upload:
#   ftps — FTP over explicit TLS (recommended, encrypts login and data).
#           Your FTP client's "Encryption: TLS/SSL Explicit" setting.
#   ftp  — Plain FTP (no encryption; passwords and data sent in cleartext).
#           Only use on a fully trusted private network.
UPLOAD_PROTOCOL=ftps

UPLOAD_HOST=your.server.tld
UPLOAD_PORT=21
UPLOAD_USER=youruser
UPLOAD_PASS=yourpassword

# Remote directory on the FTP server. Must already exist.
UPLOAD_DEST_DIR=/public_html/cam

# Filename written on the remote server.
UPLOAD_REMOTE_NAME=latest.jpg

# Verify the server's TLS certificate (FTPS only).
# true  — recommended; protects against man-in-the-middle attacks.
# false — disable for servers with self-signed/expired certificates.
#         A warning is logged when verification is disabled.
UPLOAD_TLS_VERIFY=true
